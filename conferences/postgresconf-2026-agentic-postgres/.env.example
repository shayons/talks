# Copy to .env and adjust if you're not using the local postgres.
DATABASE_URL=postgresql://coffee:coffee@localhost:5432/coffee

# Default fastembed model. Any 384-dim model works drop-in.
# EMBED_MODEL=BAAI/bge-small-en-v1.5

# Bedrock (us-east-1 by default). Override if you have access in a different
# region or want to pin a different Claude model family.
# AWS_REGION=us-east-1
# BEDROCK_HAIKU_MODEL=global.anthropic.claude-haiku-4-5-20251001-v1:0
# BEDROCK_OPUS_MODEL=global.anthropic.claude-opus-4-7
